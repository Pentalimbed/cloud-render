{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-msvc-vcpkg",
      "displayName": "Windows MSVC vcpkg",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-vs-vcpkg",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "CLOUD_RENDER_ENABLE_DEBUG_VIZ": true
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc-vcpkg",
      "configurePreset": "windows-msvc-vcpkg",
      "configuration": "RelWithDebInfo"
    }
  ]
}
